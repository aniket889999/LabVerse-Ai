// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum UserRole {
  VISITOR
  STUDENT
  FACULTY_ADMIN
  INDUSTRY_PARTNER
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum RequestType {
  PHYSICAL_VISIT
  ONLINE_DEMO
  PARTNERSHIP
}

enum LabType {
  WAREHOUSE_INVENTORY
  LOGISTICS_SIMULATION_DIGITAL_TWIN
  SMART_SUPPLY_CHAIN
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AnalyticsEventType {
  PAGE_VIEW
  LAB_VIEW
  EQUIPMENT_CLICK
  PROJECT_VIEW
  AI_QUESTION
  BOOKING_SUBMITTED
  TOUR_STARTED
  TOUR_STEP_VIEWED
  TOUR_COMPLETED
  BOOK_VISIT_CLICKED
  HOTSPOT_CLICKED
}

// MODELS

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         UserRole       @default(STUDENT)
  firstName    String?
  lastName     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  managedLabs  Lab[]          @relation("LabFacultyAdmin")
  projects     Project[]      @relation("ProjectAuthor")
  bookings     Booking[]      @relation("UserBookings")
  analytics    AnalyticsEvent[]
}

model Lab {
  id             String                @id @default(uuid())
  name           String
  description    String?
  labType        LabType
  facultyAdminId String
  capacity       Int                   @default(0)
  location       String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  facultyAdmin   User                  @relation("LabFacultyAdmin", fields: [facultyAdminId], references: [id])
  equipment      Equipment[]
  projects       Project[]
  bookings       Booking[]
  guidedTours    GuidedTour[]
  aiDocuments    AiKnowledgeDocument[]
}

model Equipment {
  id          String   @id @default(uuid())
  labId       String
  name        String
  description String?
  status      String   @default("AVAILABLE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lab         Lab      @relation(fields: [labId], references: [id])
}

model Project {
  id          String         @id @default(uuid())
  labId       String
  authorId    String
  title       String
  description String?
  repoLink    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  lab         Lab            @relation(fields: [labId], references: [id])
  author      User           @relation("ProjectAuthor", fields: [authorId], references: [id])
  media       ProjectMedia[]
}

model ProjectMedia {
  id        String    @id @default(uuid())
  projectId String
  mediaType MediaType
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Booking {
  id                String        @id @default(uuid())
  requesterName     String
  requesterEmail    String
  organizationName  String?
  role              String?
  requestType       RequestType   @default(PHYSICAL_VISIT)
  
  preferredDate     DateTime?
  preferredTimeSlot String?
  purpose           String?
  message           String?

  status            BookingStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  userId            String?
  labId             String?

  user              User?         @relation("UserBookings", fields: [userId], references: [id])
  lab               Lab?          @relation(fields: [labId], references: [id])
}

model AnalyticsEvent {
  id        String             @id @default(uuid())
  eventType AnalyticsEventType
  userId    String?
  metadata  Json?
  timestamp DateTime           @default(now())

  user      User?              @relation(fields: [userId], references: [id])
}

model GuidedTour {
  id          String     @id @default(uuid())
  labId       String
  title       String
  description String?
  durationMin Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lab         Lab        @relation(fields: [labId], references: [id])
  steps       TourStep[]
}

model TourStep {
  id           String     @id @default(uuid())
  guidedTourId String
  stepNumber   Int
  title        String
  content      String
  mediaUrl     String?
  createdAt    DateTime   @default(now())

  guidedTour   GuidedTour @relation(fields: [guidedTourId], references: [id], onDelete: Cascade)
}

model AiKnowledgeDocument {
  id        String   @id @default(uuid())
  labId     String
  title     String
  content   String   @db.Text
  sourceUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lab       Lab      @relation(fields: [labId], references: [id])
}
